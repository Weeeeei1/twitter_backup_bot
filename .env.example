# Bot Configuration
BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_ID=123456789

# Private Channel (get from @userinfobot or create channel, add bot as admin, then get channel ID)
PRIVATE_CHANNEL_ID=-1003922641317

# Twitter Cookies (JSON string)
TWITTER_COOKIES=[{"domain":".x.com","name":"auth_token","value":"..."}]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/twitter_backup

# Redis
REDIS_URL=redis://localhost:6379/0

# Scheduler
BASE_CHECK_INTERVAL=300
MIN_CHECK_INTERVAL=60
MAX_CHECK_INTERVAL=3600

# Application
LOG_LEVEL=INFO
VERSION=v0.1.0
